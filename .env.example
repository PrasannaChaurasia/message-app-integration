# Claude AI Agent — Environment Template
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains private keys.

# ── Required ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get from: https://console.anthropic.com

OPENAI_API_KEY=your_openai_api_key_here
# Get from: https://platform.openai.com/api-keys
# Required for: voice note transcription, video transcription, DALL-E image generation

# ── Model config ────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_RESPONSE_LENGTH=4000

# ── WhatsApp ────────────────────────────────────────────────
WHATSAPP_SESSION_PATH=./baileys-session
# Restrict to specific numbers (country code, no +). Leave empty to allow all.
ALLOWED_NUMBERS=447700000000
COMMAND_PREFIX=

# ── Slack (optional — bot starts without this) ───────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Get from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-token
# Get from: api.slack.com → Your App → Basic Information → App-Level Tokens

# ── Discord (optional — bot starts without this) ─────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
# Get from: discord.com/developers → Your App → Bot → Token

# ── Notion (optional) ────────────────────────────────────────
NOTION_TOKEN=secret_your_notion_token
# Get from: notion.so/my-integrations
