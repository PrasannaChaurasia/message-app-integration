# ─────────────────────────────────────────
# Claude Message App Integration — ENV
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────

# Anthropic API Key (required)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WhatsApp session storage path
WHATSAPP_SESSION_PATH=./session

# Allowed phone numbers (optional — leave blank to allow all)
# Format: comma-separated, country code only, no + or spaces
# Example: 447911123456,447922654321
ALLOWED_NUMBERS=

# Optional command prefix — only messages starting with this are processed
# Leave blank to process all incoming messages
# Example: /claude
COMMAND_PREFIX=

# Max Claude response length in characters (WhatsApp limit ~4096)
MAX_RESPONSE_LENGTH=4000

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6
