# Claude Message App Integration — ENV template
# Copy to .env and fill in values. Never commit .env to git.

# ── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── WhatsApp ───────────────────────────────────────────────
WHATSAPP_SESSION_PATH=./session
# Your phone number (country code, no +). Only this number gets replies.
ALLOWED_NUMBERS=447776361383

# ── Slack (optional) ───────────────────────────────────────
# Get from: api.slack.com → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Get from: api.slack.com → Your App → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token

# ── Discord (optional) ─────────────────────────────────────
# Get from: discord.com/developers → Your App → Bot → Token
DISCORD_BOT_TOKEN=your-discord-bot-token

# ── OpenAI (image generation) ──────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional ───────────────────────────────────────────────
COMMAND_PREFIX=
MAX_RESPONSE_LENGTH=4000
